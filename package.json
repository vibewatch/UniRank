{
  "name": "unirank",
  "type": "module",
  "version": "0.1.0",
  "description": "UniRank — Astro insights site over a worldwide university-ranking archive, with a Node.js scraper as supporting scripts.",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "astro dev --background",
    "dev:status": "astro dev status",
    "dev:stop": "astro dev stop",
    "check": "astro check",
    "build": "astro build",
    "verify": "npm run check && npm run build",
    "preview": "astro preview",
    "astro": "astro",
    "scrape": "node scraper/cli.ts",
    "insights": "node scraper/insights/generate.ts",
    "data": "npm run insights",
    "typecheck:scraper": "tsc -p scraper/tsconfig.json",
    "test": "node --test tests/*.test.ts"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.3.0",
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource/space-mono": "^5.3.0",
    "astro": "^7.1.1",
    "csv-parse": "^5.5.6",
    "i18n-iso-countries": "^7.11.3",
    "linkedom": "^0.18.12",
    "pdfjs-dist": "^4.7.76",
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3"
  }
}
