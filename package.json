{
  "name": "unirank",
  "type": "module",
  "version": "0.1.0",
  "description": "UniRank — Astro insights site over a worldwide university-ranking archive, with a Node.js scraper as supporting scripts.",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "check:data": "npm run insights && git diff --exit-code -- src/data/insights.json public/data/directory.json public/data/subjects src/data/directory-facets.json",
    "typecheck:scraper": "tsc -p scraper/tsconfig.json",
    "test": "node --test tests/*.test.ts",
    "verify": "npm run typecheck:scraper && npm run check:data && npm run check && npm test && npm run build",
    "scrape": "node scraper/cli.ts",
    "insights": "node scraper/insights/generate.ts",
    "data": "npm run insights"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/fraunces": "^5.3.0",
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource/space-mono": "^5.3.0",
    "astro": "^7.1.1",
    "csv-parse": "^5.5.6",
    "d3-geo": "^3.1.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "i18n-iso-countries": "^7.11.3",
    "linkedom": "^0.18.12",
    "pdfjs-dist": "^4.7.76",
    "playwright-core": "^1.61.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/node": "^22.10.0",
    "@types/topojson-client": "^3.1.5",
    "typescript": "^6.0.3"
  }
}
