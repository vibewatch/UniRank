---
import SectionHeading from '../components/SectionHeading.astro';
import SpecialistExamples from '../components/SpecialistExamples.astro';
import SubjectExplorer from '../components/SubjectExplorer.astro';
import SubjectMatrix from '../components/SubjectMatrix.astro';
import NatureLeaderboards from '../components/NatureLeaderboards.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { insights } from '../lib/data';
import { number } from '../lib/format';

const subjectLeaderCountries = insights.natureSubjects.map(
  (subject) => subject.leaders[0]?.country,
);
const countryCounts = new Map<string, number>();
subjectLeaderCountries.forEach((country) => {
  if (country) countryCounts.set(country, (countryCounts.get(country) ?? 0) + 1);
});
const split = [...countryCounts.entries()].sort((a, b) => b[1] - a[1]);
const subjectProviderCount = new Set(
  insights.subjectBoards.map((board) => board.provider),
).size;
const outperformerSubjectCount = new Set(
  insights.qsSubjectOutperformers.map((institution) => institution.subject),
).size;
const natureLeaderCount = insights.natureSubjects.reduce(
  (total, subject) => total + subject.leaders.length,
  0,
);
const subjectNote = `Subject tables from ${subjectProviderCount} rankings: QS, ShanghaiRanking (GRAS), U.S. News, Times Higher Education, NTU, SCImago research areas, and Leiden. The chart summarizes the eight largest country groups; the country menu and paginated school list use every institution with a resolved country in the selected source table. Providers differ in method—publisher rankings weight reputation and surveys while NTU, SCImago, and Leiden are bibliometric—so read each as its own lens, not a shared scale. Banded ranks use their lower bound.`;
---

<BaseLayout
  title="Study"
  description="Compare specialist subject strengths across seven rankings—QS, ShanghaiRanking GRAS, U.S. News, Times, NTU, SCImago research areas, and Leiden—plus Nature Index academic tables, with transparent limits on what subject rankings can tell you."
>
  <section class="page-hero subject-hero">
    <div class="shell hero-grid">
      <div>
        <p class="eyebrow">Program-level evidence</p>
        <h1>The broad table can hide the field that fits.</h1>
        <p class="lede">
          Specialist institutions often disappear inside an overall ranking—or
          never enter it at all. Subject tables reveal where focused research
          communities outperform their broad institutional position.
        </p>
      </div>
      <aside class="subject-stamp">
        <span class="mono">ARCHIVED VIEWS</span>
        <strong>{number.format(insights.meta.subjectViews)}</strong>
        <p>provider-specific subjects and fields across the archive</p>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeading
        eyebrow="Hidden strengths"
        title="A specialist can lead its field without appearing broadly elite."
        description={`All ${number.format(insights.qsSubjectOutperformers.length)} QS 2026 subject placements meeting one reproducible rule: subject top 10, plus an overall position of #300 or worse—or no overall listing. They span ${outperformerSubjectCount} subjects; subjects with no qualifying institution do not appear.`}
      />
      <SpecialistExamples items={insights.qsSubjectOutperformers} />
      <p class="fine-print selection-note">
        This is the complete set of placements matching the rule above, not a
        new “most underrated” ranking. A university can appear in more than one
        subject because each subject-table result is a separate observation.
      </p>
    </div>
  </section>

  <section class="section explorer-section">
    <div class="shell">
      <SectionHeading
        eyebrow="Find schools by what you want to study"
        title="Pick your subject, then see the top schools—and narrow to a country you’d actually consider."
        description="Choose a discipline to reveal its highest-ranked universities, then filter the leaderboard to a single country to build a realistic list (for example, the best computer-science schools in Canada). The bars show which countries supply the most ranked programs in that field, so you can also let strength point you toward a destination."
      />
      <SubjectExplorer
        boards={insights.subjectBoards}
        multiProvider
        note={subjectNote}
      />
    </div>
  </section>

  <section class="section nature-section">
    <div class="shell">
      <SectionHeading
        eyebrow="Nature Index 2026"
        title="Academic discipline leaders split across research systems."
        description={`All eight latest academic discipline tables are included, with ${number.format(natureLeaderCount)} published entries in total. Their #1 positions are led primarily by ${split.slice(0, 2).map(([country, count]) => `${country} (${count})`).join(' and ')}. Browse one complete table at a time below.`}
      />
      <NatureLeaderboards subjects={insights.natureSubjects} />
      <p class="fine-print nature-note">
        These are all entries in the eight Nature Index 2026 academic discipline
        tables in the archive (500 per discipline; Social sciences has 548).
        Share is a fractional publication contribution; Count is not used in
        the displayed rank. Nature Index covers a selected journal set and
        should not be generalized to teaching, access, or all scholarly fields.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeading
        eyebrow="Multi-field profile"
        title="Broad consensus does not imply uniform subject strength."
        description="Nature academic ranks for the leading multi-provider consensus cohort. A dash means the institution is outside that published subject table or could not be matched safely—not rank zero."
      />
      <SubjectMatrix subjects={insights.natureSubjects} rows={insights.subjectMatrix} />
    </div>
  </section>

  <section class="section decision-section">
    <div class="shell">
      <SectionHeading
        eyebrow="How to use a subject table"
        title="Turn a field rank into better questions."
      />
      <div class="decision-grid">
        <article>
          <span class="mono">01</span>
          <h3>Check the unit</h3>
          <p>A university-wide subject score is not a guarantee about every department, degree, or campus.</p>
        </article>
        <article>
          <span class="mono">02</span>
          <h3>Inspect the metric</h3>
          <p>Publication Share, reputation, citations, and employer surveys answer different questions.</p>
        </article>
        <article>
          <span class="mono">03</span>
          <h3>Verify the program</h3>
          <p>Compare faculty, curriculum, facilities, placement, accreditation, cost, and admissions directly.</p>
        </article>
        <article>
          <span class="mono">04</span>
          <h3>Look for durability</h3>
          <p>Prefer recurring strength across years and methods to a single unusually favorable edition.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(230px, 0.5fr);
    align-items: end;
    gap: clamp(28px, 5vw, 64px);
  }

  .subject-stamp {
    padding: 26px;
    border: 1px solid var(--line-strong);
    border-radius: 50% 50% 12px 12px;
    text-align: center;
  }

  .subject-stamp span {
    color: var(--muted);
    font-size: 0.6rem;
  }

  .subject-stamp strong {
    display: block;
    margin: 10px 0 4px;
    font-size: 4rem;
    letter-spacing: -0.07em;
    line-height: 1;
  }

  .subject-stamp p {
    max-width: 180px;
    margin: 0 auto;
    color: var(--muted);
    font-size: 0.68rem;
  }

  .selection-note {
    margin: 14px 2px 0;
  }

  .nature-section {
    color: white;
    background: var(--ink);
  }

  .nature-section :global(.eyebrow) {
    color: #72ddc4;
  }

  .nature-section :global(.section-heading p:last-child) {
    color: #9ca6aa;
  }

  .nature-note {
    margin: 14px 2px 0;
    color: #8e999e;
  }

  .decision-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .decision-grid article {
    padding: 23px;
  }

  .decision-grid article + article {
    border-left: 1px solid var(--line);
  }

  .decision-grid span {
    display: inline-grid;
    width: 34px;
    height: 34px;
    margin-bottom: 30px;
    place-items: center;
    border-radius: 50%;
    color: white;
    background: var(--violet);
    font-size: 0.59rem;
  }

  .decision-grid p {
    margin: 0;
    color: var(--muted);
    font-size: 0.73rem;
  }

  @media (max-width: 900px) {
    .decision-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .decision-grid article:nth-child(3) {
      border-left: 0;
    }

    .decision-grid article:nth-child(n + 3) {
      border-top: 1px solid var(--line);
    }
  }

  @media (max-width: 620px) {
    .hero-grid,
    .decision-grid {
      grid-template-columns: 1fr;
    }

    .subject-stamp {
      max-width: 260px;
    }

    .decision-grid article + article {
      border-top: 1px solid var(--line);
      border-left: 0;
    }
  }
</style>
