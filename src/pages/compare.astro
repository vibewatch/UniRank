---
import MetricCard from '../components/MetricCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SHORTLIST_MAX } from '../lib/shortlist';
---

<BaseLayout
  title="Compare"
  description="Build a shortlist of universities and compare them side by side — every provider's rank, country, and multi-source coverage in one table — so you can weigh your options before you apply."
>
  <section class="page-hero compare-hero">
    <div class="shell">
      <p class="eyebrow">Your shortlist</p>
      <h1>Put your choices side by side.</h1>
      <p class="lede">
        Add up to {SHORTLIST_MAX} universities from the Find page or the search
        below, then read every ranking&rsquo;s verdict in one place. Different
        providers measure different things&mdash;seeing them together is how you
        judge a school for yourself instead of trusting one number.
      </p>
    </div>
  </section>

  <section class="section compare-section">
    <div class="shell">
      <div class="compare-toolbar surface">
        <label class="add-school">
          <span>Add a university</span>
          <div class="add-field">
            <input
              type="search"
              placeholder="Search by name or country…"
              data-add-search
              autocomplete="off"
              aria-label="Search for a university to add to your comparison"
            />
            <ul class="add-results" data-add-results hidden></ul>
          </div>
        </label>
        <div class="toolbar-meta">
          <p data-compare-count aria-live="polite">Loading your shortlist…</p>
          <button type="button" class="button ghost" data-clear hidden>Clear all</button>
        </div>
      </div>

      <div data-compare>
        <div class="compare-empty surface" data-empty hidden>
          <h2>Your comparison is empty.</h2>
          <p>
            Search above, or open the <a href="/finder/">Find a university</a>
            page and use the <b>Compare</b> checkbox on any result to build a
            shortlist of up to {SHORTLIST_MAX} schools.
          </p>
          <div class="empty-suggest" data-suggest hidden>
            <span class="mono">Popular starting points</span>
            <div class="suggest-chips" data-suggest-chips></div>
          </div>
        </div>
        <div class="compare-scroll" data-grid-wrap hidden>
          <table class="compare-grid" data-grid></table>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeading
        eyebrow="Reading the comparison"
        title="A wider row means broader agreement, not a better school."
      />
      <div class="grid three read-grid">
        <MetricCard
          label="Bolded rank"
          value="Best in row"
          detail="For each ranking, the strongest position among your shortlisted schools is highlighted."
          tone="teal"
          index="01"
        />
        <MetricCard
          label="Coverage"
          value="of 10"
          detail="How many providers rank the school at all. More coverage means a more stable picture, not higher quality."
          tone="violet"
          index="02"
        />
        <MetricCard
          label="Consensus"
          value="4+ sources"
          detail="A consensus rank only exists when four or more broad providers agree the school belongs near the top."
          tone="coral"
          index="03"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import {
    SHORTLIST_MAX,
    readShortlist,
    removeFromShortlist,
    addManyToShortlist,
    clearShortlist,
    subscribeShortlist,
  } from '../lib/shortlist';

  const PROVIDER_ABBR: Record<string, string> = {
    usnews: 'USN', times: 'THE', qs: 'QS', cwur: 'CWUR', ntu: 'NTU',
    arwu: 'ARWU', scimago: 'SCI', nature: 'NAT', openalex: 'OA', leiden: 'LEI',
  };
  const SUGGESTED = [
    'massachusetts-institute-of-technology-us',
    'university-of-oxford-gb',
    'stanford-university-us',
    'national-university-of-singapore-sg',
  ];

  type DirectoryRank = [number, string, number];
  interface DirectoryInstitution {
    id: string;
    name: string;
    country: string;
    countryCode: string | null;
    providerCount: number;
    consensusRank: number | null;
    ranks: Record<string, DirectoryRank>;
  }
  interface DirectoryProvider { id: string; label: string; color: string; year: number | null }
  interface Directory { providers: DirectoryProvider[]; institutions: DirectoryInstitution[] }

  const asciiFold = (value: string): string =>
    value.toLowerCase().normalize('NFKD').replace(/[\u0300-\u036f]/g, '');

  const initializeCompare = async (root: HTMLElement): Promise<void> => {
    if (root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    const grid = root.querySelector<HTMLTableElement>('[data-grid]');
    const gridWrap = root.querySelector<HTMLElement>('[data-grid-wrap]');
    const empty = root.querySelector<HTMLElement>('[data-empty]');
    const suggest = root.querySelector<HTMLElement>('[data-suggest]');
    const suggestChips = root.querySelector<HTMLElement>('[data-suggest-chips]');
    const section = root.closest('.compare-section');
    const countEl = section?.querySelector<HTMLElement>('[data-compare-count]');
    const clearBtn = section?.querySelector<HTMLButtonElement>('[data-clear]');
    const addSearch = section?.querySelector<HTMLInputElement>('[data-add-search]');
    const addResults = section?.querySelector<HTMLUListElement>('[data-add-results]');
    if (!grid || !gridWrap || !empty || !countEl) return;

    let directory: Directory;
    try {
      const response = await fetch('/data/directory.json');
      if (!response.ok) throw new Error(String(response.status));
      directory = (await response.json()) as Directory;
    } catch {
      countEl.textContent = 'The institution index could not be loaded. Please retry later.';
      return;
    }

    const byId = new Map(directory.institutions.map((item) => [item.id, item]));
    const providers = directory.providers;

    // Merge any ?ids= share param into the stored shortlist on first load.
    const shareIds = new URLSearchParams(location.search).get('ids');
    if (shareIds) addManyToShortlist(shareIds.split(',').map((id) => id.trim()).filter(Boolean));

    const writeShareUrl = (ids: string[]): void => {
      const query = ids.length ? `?ids=${ids.join(',')}` : '';
      const next = `${location.pathname}${query}`;
      if (next !== `${location.pathname}${location.search}`) history.replaceState(null, '', next);
    };

    const removeButton = (id: string): HTMLButtonElement => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'remove';
      button.setAttribute('aria-label', 'Remove from comparison');
      button.textContent = '\u00d7';
      button.addEventListener('click', () => removeFromShortlist(id));
      return button;
    };

    const render = (): void => {
      const ids = readShortlist();
      const schools = ids.map((id) => byId.get(id)).filter((item): item is DirectoryInstitution => Boolean(item));
      writeShareUrl(schools.map((school) => school.id));

      countEl.textContent = schools.length
        ? `${schools.length} of ${SHORTLIST_MAX} schools`
        : 'No schools yet';
      if (clearBtn) clearBtn.hidden = schools.length === 0;

      if (!schools.length) {
        gridWrap.hidden = true;
        empty.hidden = false;
        if (suggest && suggestChips && !suggestChips.childElementCount) {
          const chips = SUGGESTED.map((id) => byId.get(id)).filter((item): item is DirectoryInstitution => Boolean(item));
          for (const school of chips) {
            const chip = document.createElement('button');
            chip.type = 'button';
            chip.className = 'suggest-chip';
            chip.textContent = school.name;
            chip.addEventListener('click', () => addManyToShortlist([school.id]));
            suggestChips.append(chip);
          }
          suggest.hidden = chips.length === 0;
        }
        return;
      }

      empty.hidden = true;
      gridWrap.hidden = false;

      const rows: HTMLTableRowElement[] = [];

      // Header: one column per school.
      const headRow = document.createElement('tr');
      headRow.append(document.createElement('th'));
      for (const school of schools) {
        const th = document.createElement('th');
        th.scope = 'col';
        th.className = 'school-head';
        const name = document.createElement('strong');
        name.textContent = school.name;
        const place = document.createElement('small');
        place.textContent = school.country || 'Location n/a';
        th.append(removeButton(school.id), name, place);
        headRow.append(th);
      }
      rows.push(headRow);

      const labelCell = (text: string, hint?: string): HTMLTableCellElement => {
        const th = document.createElement('th');
        th.scope = 'row';
        th.className = 'row-label';
        const strong = document.createElement('span');
        strong.textContent = text;
        th.append(strong);
        if (hint) {
          const small = document.createElement('small');
          small.textContent = hint;
          th.append(small);
        }
        return th;
      };

      // Consensus rank row.
      const consensusRow = document.createElement('tr');
      consensusRow.append(labelCell('Consensus rank', '4+ broad sources'));
      const consensusValues = schools.map((school) => school.consensusRank ?? Number.POSITIVE_INFINITY);
      const bestConsensus = Math.min(...consensusValues);
      for (const school of schools) {
        const td = document.createElement('td');
        if (school.consensusRank === null) {
          td.className = 'muted';
          td.textContent = 'Not in consensus';
        } else {
          td.textContent = `#${school.consensusRank}`;
          if (school.consensusRank === bestConsensus) td.classList.add('best');
        }
        consensusRow.append(td);
      }
      rows.push(consensusRow);

      // Coverage row.
      const coverageRow = document.createElement('tr');
      coverageRow.append(labelCell('Coverage', `of ${providers.length} providers`));
      const bestCoverage = Math.max(...schools.map((school) => school.providerCount));
      for (const school of schools) {
        const td = document.createElement('td');
        td.textContent = `${school.providerCount}`;
        if (school.providerCount === bestCoverage) td.classList.add('best');
        coverageRow.append(td);
      }
      rows.push(coverageRow);

      // One row per provider.
      for (const provider of providers) {
        const anyRanked = schools.some((school) => school.ranks[provider.id]);
        if (!anyRanked) continue;
        const row = document.createElement('tr');
        row.append(labelCell(provider.label, provider.year ? `${provider.year}` : undefined));
        const numeric = schools.map((school) => school.ranks[provider.id]?.[0] ?? Number.POSITIVE_INFINITY);
        const best = Math.min(...numeric);
        for (const school of schools) {
          const td = document.createElement('td');
          const entry = school.ranks[provider.id];
          if (!entry) {
            td.className = 'muted';
            td.textContent = '\u2014';
          } else {
            const tag = document.createElement('b');
            tag.className = 'prov-tag';
            tag.style.setProperty('--chip', provider.color || 'var(--muted)');
            tag.textContent = PROVIDER_ABBR[provider.id] ?? provider.id.toUpperCase();
            td.append(tag, document.createTextNode(entry[1]));
            if (entry[0] === best) td.classList.add('best');
          }
          row.append(td);
        }
        rows.push(row);
      }

      grid.replaceChildren(...rows);
    };

    // "Add a university" search suggestions.
    if (addSearch && addResults) {
      const folded = directory.institutions.map((item) => ({
        item,
        hay: `${asciiFold(item.name)} ${asciiFold(item.country)}`,
      }));
      const closeResults = (): void => { addResults.hidden = true; addResults.replaceChildren(); };
      const runSearch = (): void => {
        const tokens = asciiFold(addSearch.value.trim()).split(/\s+/).filter(Boolean);
        if (!tokens.length) { closeResults(); return; }
        const current = new Set(readShortlist());
        const matches = folded
          .filter(({ item, hay }) => !current.has(item.id) && tokens.every((token) => hay.includes(token)))
          .sort((a, b) => {
            const ar = a.item.consensusRank ?? Number.POSITIVE_INFINITY;
            const br = b.item.consensusRank ?? Number.POSITIVE_INFINITY;
            return ar !== br ? ar - br : b.item.providerCount - a.item.providerCount;
          })
          .slice(0, 8);
        if (!matches.length) { closeResults(); return; }
        const atMax = current.size >= SHORTLIST_MAX;
        const items = matches.map(({ item }) => {
          const li = document.createElement('li');
          const button = document.createElement('button');
          button.type = 'button';
          button.disabled = atMax;
          button.innerHTML = `<strong>${item.name}</strong><small>${item.country || ''}</small>`;
          button.addEventListener('click', () => {
            addManyToShortlist([item.id]);
            addSearch.value = '';
            closeResults();
            addSearch.focus();
          });
          li.append(button);
          return li;
        });
        if (atMax) {
          const note = document.createElement('li');
          note.className = 'add-note';
          note.textContent = `Remove a school to add another (max ${SHORTLIST_MAX}).`;
          items.unshift(note);
        }
        addResults.replaceChildren(...items);
        addResults.hidden = false;
      };
      addSearch.addEventListener('input', runSearch);
      addSearch.addEventListener('focus', runSearch);
      document.addEventListener('click', (event) => {
        if (!addResults.contains(event.target as Node) && event.target !== addSearch) closeResults();
      });
    }

    clearBtn?.addEventListener('click', () => clearShortlist());
    subscribeShortlist(() => render());
    render();
  };

  const boot = (): void => {
    document.querySelectorAll<HTMLElement>('[data-compare]').forEach((root) => void initializeCompare(root));
  };
  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .compare-hero { padding-bottom: 20px; }
  .compare-section { padding-top: 32px; }

  .compare-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px 24px;
    padding: 16px;
    margin-bottom: 22px;
  }
  .add-school { display: grid; gap: 5px; flex: 1 1 320px; min-width: 260px; }
  .add-school > span {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.59rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .add-field { position: relative; }
  .add-field input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface);
    font: inherit;
  }
  .add-results {
    position: absolute;
    z-index: 20;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    margin: 0;
    padding: 4px;
    list-style: none;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface);
    box-shadow: var(--shadow-pop);
    max-height: 320px;
    overflow: auto;
  }
  .add-results li button {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 1px;
    padding: 8px 10px;
    border: 0;
    border-radius: 8px;
    background: transparent;
    text-align: left;
    cursor: pointer;
  }
  .add-results li button:hover:not(:disabled),
  .add-results li button:focus-visible { background: rgb(23 160 133 / 10%); }
  .add-results li button:disabled { cursor: not-allowed; opacity: 0.5; }
  .add-results li button small { color: var(--muted); font-size: 0.72rem; }
  .add-results .add-note {
    padding: 8px 10px;
    color: var(--muted);
    font-size: 0.72rem;
  }
  .toolbar-meta { display: flex; align-items: center; gap: 14px; }
  .toolbar-meta p { margin: 0; font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
  .button.ghost {
    padding: 7px 14px;
    background: transparent;
    border: 1px solid var(--line);
    color: var(--ink);
    font-size: 0.8rem;
  }

  .compare-empty { padding: clamp(1.75rem, 4vw, 3rem); text-align: center; }
  .compare-empty h2 { margin: 0 0 0.5rem; font-size: 1.3rem; }
  .compare-empty p { margin: 0 auto; max-width: 46ch; color: var(--muted); }
  .empty-suggest { margin-top: 1.5rem; }
  .empty-suggest .mono {
    display: block;
    margin-bottom: 0.6rem;
    color: var(--muted);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .suggest-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
  .suggest-chip {
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    font: inherit;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .suggest-chip:hover, .suggest-chip:focus-visible { border-color: var(--teal); }

  .compare-scroll { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--radius-md); background: var(--surface); }
  .compare-grid { width: 100%; border-collapse: collapse; min-width: 520px; }
  .compare-grid th, .compare-grid td {
    padding: 12px 14px;
    text-align: left;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
  }
  .compare-grid tr:last-child th, .compare-grid tr:last-child td { border-bottom: 0; }
  .compare-grid .school-head {
    position: relative;
    min-width: 150px;
    border-left: 1px solid var(--line);
    background: rgb(23 160 133 / 6%);
  }
  .compare-grid .school-head strong { display: block; font-size: 0.92rem; padding-right: 1.2rem; }
  .compare-grid .school-head small { color: var(--muted); font-size: 0.72rem; }
  .compare-grid .remove {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 20px;
    height: 20px;
    padding: 0;
    line-height: 1;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: var(--muted);
    cursor: pointer;
  }
  .compare-grid .remove:hover { border-color: #b64738; color: #b64738; }
  .compare-grid .row-label { min-width: 130px; background: rgb(0 0 0 / 1.5%); }
  .compare-grid .row-label span { display: block; font-size: 0.86rem; font-weight: 620; }
  .compare-grid .row-label small { color: var(--muted); font-size: 0.68rem; font-family: var(--font-mono); }
  .compare-grid td { border-left: 1px solid var(--line); font-size: 0.9rem; }
  .compare-grid td.muted { color: var(--muted); }
  .compare-grid td.best { font-weight: 720; color: var(--teal-dark); }
  .prov-tag {
    display: inline-block;
    margin-right: 6px;
    padding: 1px 5px;
    border-radius: 5px;
    background: var(--chip, var(--muted));
    color: white;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    vertical-align: middle;
  }

  .read-grid { margin-top: 6px; }

  @media (max-width: 640px) {
    .compare-toolbar { flex-direction: column; align-items: stretch; }
    .toolbar-meta { justify-content: space-between; }
  }
</style>
