---
import MetricCard from '../components/MetricCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import UniversityFinder from '../components/UniversityFinder.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import facets from '../data/directory-facets.json';
import { insights } from '../lib/data';
import type { DirectoryFacets } from '../data/schema';

const directory = facets as DirectoryFacets;
const totalInstitutions = directory.meta.count;
const subjectTableCount = insights.subjectBoards.length;

// Schools that sit inside every one of the six broad providers' displayed top
// 20 — the strongest "everyone agrees" trust anchor for an overwhelmed student.
const universalTop20 = insights.consensus.filter(
  (institution) =>
    institution.providerCount === 6 && institution.ranks.every((rank) => rank.rank <= 20),
);
---

<BaseLayout
  title="Find"
  description="Find universities by subject strength in one provider's published table, or search the overall directory across ten worldwide ranking sources."
>
  <section class="page-hero finder-hero">
    <div class="shell">
      <p class="eyebrow">Find a university</p>
      <h1>Start with what you want to study.</h1>
      <p class="lede">
        Choose a ranking source and subject to see that complete published table
        in rank order—or switch to the overall directory to look up any school.
        Sources stay separate because a QS subject rank and a bibliometric field
        rank do not measure the same thing.
      </p>
      <div class="grid two metric-grid">
        <MetricCard
          label="Institutions indexed"
          value={totalInstitutions.toLocaleString('en-US')}
          detail="Every school in the latest overall or broad ranking tables, searchable in one place."
          tone="teal"
          index="01"
        />
        <MetricCard
          label="Subject tables"
          value={subjectTableCount.toLocaleString('en-US')}
          detail="Complete provider-specific disciplines and fields, available on demand."
          tone="violet"
          index="02"
        />
      </div>
    </div>
  </section>

  <section class="section finder-section">
    <div class="shell">
      <SectionHeading
        eyebrow="Live query"
        title="Choose a subject table—or search the overall directory."
        description="Subject mode is ordered by the selected provider's published rank and includes every institution in that table. Overall mode removes redundant ranking controls and simply prioritizes broad consensus, then coverage."
        href="/methodology/#providers"
        linkLabel="Why sources stay separate"
      />

      <UniversityFinder
        directory={directory}
        subjectBoards={insights.subjectBoards}
      />
    </div>
  </section>

  <section class="section elite-section">
    <div class="shell">
      <SectionHeading
        eyebrow="Not sure where to start?"
        title="Schools every major broad ranking calls elite."
        description="These institutions sit inside all six broad providers' displayed top 20 at once. It is a strict agreement test, not another weighted score—a safe anchor before you branch into subject and country fit."
        href="/subjects/"
        linkLabel="Then match your subject"
      />
      <div class="elite-cloud">
        {universalTop20.map((institution, index) => (
          <article class="surface">
            <span class="mono">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <strong>{institution.name}</strong>
              <small>{institution.country}</small>
            </div>
            <span class="range" title="Best–worst rank across the six broad providers">
              {`${Math.min(...institution.ranks.map((rank) => rank.rank))}–${Math.max(...institution.ranks.map((rank) => rank.rank))}`}
            </span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeading
        eyebrow="Reading the results"
        title="A subject rank answers one specific question."
      />
      <div class="use-grid">
        <article class="good">
          <span>Use it for</span>
          <h3>Finding strength in your field</h3>
          <p>Pick one source and discipline, then filter its full published table by country or institution name.</p>
        </article>
        <article class="good">
          <span>Use it for</span>
          <h3>Looking up any institution</h3>
          <p>Switch to the overall directory to see every provider that ranks a school, without extra filter-and-sort duplication.</p>
        </article>
        <article class="avoid">
          <span>Do not read it as</span>
          <h3>A cross-provider subject score</h3>
          <p>Subject definitions, methods, and table sizes differ. Compare evidence, but do not average unlike ranks.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .finder-hero {
    padding-bottom: 20px;
  }

  .metric-grid {
    margin-top: 24px;
  }

  .finder-section {
    padding-top: 20px;
  }

  .use-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .use-grid article {
    min-height: 210px;
    padding: 24px;
    border: 1px solid var(--line);
    border-top: 5px solid var(--teal);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .use-grid article.avoid {
    border-top-color: var(--coral);
  }

  .use-grid span {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    text-transform: uppercase;
  }

  .use-grid h3 {
    margin-top: 34px;
  }

  .use-grid p {
    color: var(--muted);
    font-size: 0.76rem;
  }

  .elite-section {
    padding-top: 8px;
  }

  .elite-cloud {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
    margin-top: 22px;
  }

  .elite-cloud article {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    padding: 12px 14px;
  }

  .elite-cloud .mono {
    color: var(--muted);
    font-size: 0.72rem;
  }

  .elite-cloud div {
    min-width: 0;
    flex: 1;
  }

  .elite-cloud strong {
    display: block;
    overflow: hidden;
    font-size: 0.9rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .elite-cloud small {
    color: var(--muted);
    font-size: 0.72rem;
  }

  .elite-cloud .range {
    flex: none;
    color: var(--teal-dark);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .use-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .elite-cloud {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>