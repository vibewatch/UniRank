---
import type { ConsensusInstitution } from '../data/schema';
import CustomSelect from './CustomSelect.astro';

interface Props {
  institutions: ConsensusInstitution[];
  limit?: number;
  interactive?: boolean;
}

const {
  institutions,
  limit = institutions.length,
  interactive = false,
} = Astro.props;
const shown = institutions.slice(0, limit);
const countries = [...new Set(shown.map((item) => item.country))].sort();
const providerShort: Record<string, string> = {
  usnews: 'USN',
  times: 'THE',
  qs: 'QS',
  cwur: 'CWUR',
  ntu: 'NTU',
  arwu: 'ARWU',
};
---

<div
  class="consensus"
  data-consensus-table
  data-interactive={interactive ? 'true' : 'false'}
>
  {interactive && (
    <div class="filters surface">
      <label class="search">
        <span>Search institution</span>
        <input type="search" placeholder="Try Oxford, Tsinghua, Toronto…" data-search />
      </label>
      <label>
        <span>Country</span>
        <CustomSelect data-country aria-label="Filter by country">
          <option value="">All countries</option>
          {countries.map((country) => <option value={country}>{country}</option>)}
        </CustomSelect>
      </label>
      <label>
        <span>Coverage</span>
        <CustomSelect data-coverage aria-label="Filter by provider coverage">
          <option value="4">4+ providers</option>
          <option value="5">5+ providers</option>
          <option value="6">All 6 providers</option>
        </CustomSelect>
      </label>
      <p data-result-count aria-live="polite">{shown.length} institutions</p>
    </div>
  )}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Signal rank</th>
          <th>Institution</th>
          <th>Consensus</th>
          <th>Provider evidence</th>
        </tr>
      </thead>
      <tbody>
        {shown.map((institution) => (
          <tr
            data-row
            data-search={`${institution.name} ${institution.country}`.toLowerCase()}
            data-country={institution.country}
            data-provider-count={institution.providerCount}
          >
            <td><strong class="signal-rank">#{institution.consensusRank}</strong></td>
            <td>
              <strong class="institution-name">{institution.name}</strong>
              <small>{institution.country}</small>
            </td>
            <td>
              <strong class="score">{institution.score.toFixed(1)}</strong>
              <small>{institution.providerCount}/6 sources</small>
            </td>
            <td>
              <div class="rank-chips">
                {institution.ranks.map((rank) => (
                  <span title={`${rank.providerLabel} ${rank.year}: ${rank.rankDisplay}`}>
                    <b>{providerShort[rank.provider] ?? rank.provider.toUpperCase()}</b>
                    {rank.rankDisplay}
                  </span>
                ))}
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<script>
  const initializeConsensusTables = () => {
    document.querySelectorAll<HTMLElement>('[data-consensus-table][data-interactive="true"]')
      .forEach((root) => {
        if (root.dataset.initialized === 'true') return;
        root.dataset.initialized = 'true';
        const search = root.querySelector<HTMLInputElement>('[data-search]');
        const country = root.querySelector<HTMLSelectElement>('[data-country]');
        const coverage = root.querySelector<HTMLSelectElement>('[data-coverage]');
        const count = root.querySelector<HTMLElement>('[data-result-count]');
        const rows = [...root.querySelectorAll<HTMLTableRowElement>('[data-row]')];

        const filter = () => {
          const query = search?.value.trim().toLowerCase() ?? '';
          const selectedCountry = country?.value ?? '';
          const minimumCoverage = Number(coverage?.value ?? 4);
          let visible = 0;
          rows.forEach((row) => {
            const matches =
              (row.dataset.search?.includes(query) ?? false) &&
              (!selectedCountry || row.dataset.country === selectedCountry) &&
              Number(row.dataset.providerCount) >= minimumCoverage;
            row.hidden = !matches;
            if (matches) visible += 1;
          });
          if (count) count.textContent = `${visible} institution${visible === 1 ? '' : 's'}`;
          writeUrl();
        };

        const DEFAULTS: Record<string, string> = { q: '', country: '', coverage: '4' };
        const controls: Record<string, HTMLInputElement | HTMLSelectElement | null> = { q: search, country, coverage };
        let suppress = false;

        const writeUrl = () => {
          const params = new URLSearchParams();
          for (const [key, element] of Object.entries(controls)) {
            const value = element?.value ?? '';
            if (value && value !== DEFAULTS[key]) params.set(key, value);
          }
          const query = params.toString();
          const next = `${location.pathname}${query ? `?${query}` : ''}${location.hash}`;
          if (next !== `${location.pathname}${location.search}${location.hash}`) history.replaceState(null, '', next);
        };

        const readUrl = () => {
          const params = new URLSearchParams(location.search);
          suppress = true;
          for (const [key, element] of Object.entries(controls)) {
            if (!element) continue;
            const value = params.get(key) ?? DEFAULTS[key];
            if (element.value === value) continue;
            element.value = value;
            if (element instanceof HTMLSelectElement) element.dispatchEvent(new Event('change', { bubbles: true }));
          }
          suppress = false;
        };

        const onControlChange = () => { if (!suppress) filter(); };
        search?.addEventListener('input', onControlChange);
        country?.addEventListener('change', onControlChange);
        coverage?.addEventListener('change', onControlChange);
        window.addEventListener('popstate', () => { readUrl(); filter(); });

        readUrl();
        filter();
      });
  };

  initializeConsensusTables();
  document.addEventListener('astro:page-load', initializeConsensusTables);
</script>

<style>
  .filters {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 0.8fr auto;
    align-items: end;
    gap: 12px;
    margin-bottom: 18px;
    padding: 16px;
  }

  label {
    display: grid;
    gap: 5px;
  }

  label span {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.59rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  input,
  select {
    min-height: 42px;
    padding: 8px 11px;
    border: 1px solid var(--line-strong);
    border-radius: 9px;
    color: var(--ink);
    background: var(--surface);
    font-size: 0.76rem;
  }

  .filters p {
    min-width: 105px;
    margin: 0 0 10px;
    color: var(--muted);
    font-size: 0.68rem;
    text-align: right;
  }

  .signal-rank {
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .institution-name,
  td small {
    display: block;
  }

  .institution-name {
    max-width: 280px;
    font-size: 0.78rem;
  }

  td small {
    color: var(--muted);
    font-size: 0.62rem;
  }

  .score {
    color: var(--teal-dark);
    font-size: 1rem;
  }

  .rank-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    min-width: 260px;
  }

  .rank-chips span {
    display: inline-flex;
    gap: 4px;
    padding: 4px 6px;
    border: 1px solid #dfdcd4;
    border-radius: 6px;
    color: #5a656b;
    background: #f8f6f0;
    font-family: var(--font-mono);
    font-size: 0.55rem;
  }

  .rank-chips b {
    color: var(--ink);
  }

  tr[hidden] {
    display: none;
  }

  @media (max-width: 800px) {
    .filters {
      grid-template-columns: 1fr 1fr;
    }

    .filters p {
      margin: 0;
      text-align: left;
    }
  }

  @media (max-width: 520px) {
    .filters {
      grid-template-columns: 1fr;
    }
  }
</style>
