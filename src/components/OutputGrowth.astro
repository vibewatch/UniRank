---
import type { OpenAlexGrowth } from '../data/schema';
import { compact, decimal } from '../lib/format';

interface Props {
  items: OpenAlexGrowth[];
}

const { items } = Astro.props;
const max = Math.max(...items.map((item) => item.works2025));
---

<div class="growth surface">
  <div class="legend">
    <span><i class="from"></i>2016 works</span>
    <span><i class="to"></i>2025 works</span>
  </div>
  <ol>
    {items.map((item) => (
      <li>
        <div class="head">
          <strong>{item.name}</strong>
          <span class="country">{item.country}</span>
        </div>
        <div
          class="track"
          role="img"
          aria-label={`${item.name}: ${compact.format(item.works2016)} works in 2016 rising to ${compact.format(item.works2025)} in 2025`}
        >
          <span
            class="range"
            style={`--from:${(item.works2016 / max) * 100}%;--to:${(item.works2025 / max) * 100}%`}
          >
            <i class="from"></i>
            <i class="to"></i>
          </span>
        </div>
        <div class="values">
          <span class="mono">{compact.format(item.works2016)} → {compact.format(item.works2025)}</span>
          <b>{decimal.format(item.cagr)}% CAGR</b>
        </div>
      </li>
    ))}
  </ol>
  <p>
    Institution-work associations reconstructed from OpenAlex, not unique papers.
    CAGR is the compound annual growth rate across the nine-year window; rank is
    the 2025 output position. Recent OpenAlex years are less mature than earlier
    ones, so treat late-window growth as indicative.
  </p>
</div>

<style>
  .growth {
    padding: 22px;
  }

  .legend {
    display: flex;
    justify-content: flex-end;
    gap: 16px;
    margin-bottom: 14px;
    color: var(--muted);
    font-size: 0.66rem;
  }

  .legend span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .legend i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }

  .legend .from {
    background: #c5c3ba;
  }

  .legend .to {
    background: var(--teal);
  }

  ol {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: grid;
    grid-template-columns: 190px minmax(200px, 1fr) 150px;
    align-items: center;
    gap: 14px;
  }

  .head {
    min-width: 0;
  }

  .head strong {
    display: block;
    overflow: hidden;
    font-size: 0.75rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .country {
    color: var(--muted);
    font-size: 0.62rem;
  }

  .track {
    position: relative;
    height: 10px;
    border-radius: 99px;
    background: var(--line);
  }

  .range {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--from);
    right: calc(100% - var(--to));
    border-radius: 99px;
    background: linear-gradient(90deg, #c5c3ba, var(--teal));
  }

  .range i {
    position: absolute;
    top: 50%;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    border: 2px solid var(--surface);
  }

  .range .from {
    left: 0;
    background: #c5c3ba;
  }

  .range .to {
    left: 100%;
    background: var(--teal);
  }

  .values {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: right;
  }

  .values .mono {
    color: var(--muted);
    font-size: 0.6rem;
  }

  .values b {
    color: var(--ink);
    font-size: 0.72rem;
    font-weight: 750;
  }

  p {
    margin: 16px 6px 0;
    color: var(--muted);
    font-size: 0.68rem;
  }

  @media (max-width: 720px) {
    li {
      grid-template-columns: 130px minmax(150px, 1fr);
    }

    .values {
      display: none;
    }

    .growth {
      overflow-x: auto;
    }

    ol {
      min-width: 460px;
    }
  }
</style>
