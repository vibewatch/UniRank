---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  href?: string;
  linkLabel?: string;
}

const { eyebrow, title, description, href, linkLabel = 'Explore' } = Astro.props;
---

<header class="section-heading">
  <div>
    <p class="eyebrow">{eyebrow}</p>
    <h2>{title}</h2>
    {description && <p>{description}</p>}
  </div>
  {href && <a href={href}>{linkLabel}<span aria-hidden="true">↗</span></a>}
</header>

<style>
  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 16px;
  }

  .section-heading > div {
    max-width: 780px;
  }

  .eyebrow {
    margin-bottom: 12px;
  }

  h2 {
    margin-bottom: 12px;
  }

  p:last-child {
    max-width: 680px;
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  a {
    display: inline-flex;
    flex: none;
    align-items: center;
    gap: 7px;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--line-strong);
    font-size: 0.82rem;
    font-weight: 750;
    text-decoration: none;
  }

  a span {
    color: var(--coral);
  }

  @media (max-width: 680px) {
    .section-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 12px;
    }
  }
</style>
