---
import type { SubjectLeaderBoard } from '../data/schema';
import CustomSelect from './CustomSelect.astro';

interface Props {
  boards: SubjectLeaderBoard[];
  note?: string;
  defaultSubject?: string;
  multiProvider?: boolean;
}

const { boards, note, defaultSubject, multiProvider = false } = Astro.props;
const preferredSubject = defaultSubject ?? 'computer-science-information-systems';
const providerOrder: { provider: string; providerLabel: string }[] = [];
const seenProviders = new Set<string>();
for (const board of boards) {
  if (seenProviders.has(board.provider)) continue;
  seenProviders.add(board.provider);
  providerOrder.push({ provider: board.provider, providerLabel: board.providerLabel });
}
const showProvider = multiProvider && providerOrder.length > 1;
const initialProvider = providerOrder[0]?.provider ?? '';
const initialBoards = showProvider
  ? boards.filter((board) => board.provider === initialProvider)
  : boards;
const preferred = initialBoards.findIndex((board) => board.subject === preferredSubject);
const defaultIndex = preferred >= 0 ? preferred : 0;
const serialized = JSON.stringify(boards).replaceAll('<', '\\u003c');
const fineNote =
  note ??
  `QS 2026 subject tables. Bars count how many ranked institutions each country contributes to this field (top eight shown); the leaderboard lists the highest-placed institutions. Banded ranks use their lower bound, and a country's presence reflects listing counts, not per-program quality.`;
---

<section class="subject-explorer surface" data-subject-explorer>
  <div class="controls">
    <div class="control-fields">
      {showProvider && (
        <label>
          <span>Ranking source</span>
          <CustomSelect data-provider aria-label="Choose a ranking source">
            {providerOrder.map((entry, index) => (
              <option value={entry.provider} selected={index === 0}>
                {entry.providerLabel}
              </option>
            ))}
          </CustomSelect>
        </label>
      )}
      <label>
        <span>Subject table</span>
        <CustomSelect data-subject aria-label="Choose a subject table">
          {initialBoards.map((board, index) => (
            <option value={board.subject} selected={index === defaultIndex}>
              {board.label}
            </option>
          ))}
        </CustomSelect>
      </label>
      <label>
        <span>Country</span>
        <CustomSelect data-subject-country aria-label="Filter the leaderboard by country">
          <option value="">All countries</option>
        </CustomSelect>
      </label>
    </div>
    <div class="subject-summary" data-summary aria-live="polite"></div>
  </div>
  <div class="explorer-grid">
    <figure class="chart-block">
      <figcaption data-chart-caption>Ranked institutions by home system</figcaption>
      <div class="chart-frame">
        <svg
          data-chart
          viewBox="0 0 900 360"
          role="img"
          aria-label="Ranked institutions by country"
        ></svg>
      </div>
    </figure>
    <div class="leaders-block">
      <p class="leaders-title" data-leaders-title>Top institutions</p>
      <ol data-institutions class="leaders"></ol>
      <p class="leaders-empty" data-leaders-empty hidden></p>
    </div>
  </div>
  <p class="fine-print">{fineNote}</p>
  <script
    type="application/json"
    is:inline
    data-subject-data
    set:html={serialized}
  ></script>
</section>

<script>
  import { scaleLinear } from 'd3-scale';

  interface LeaderInstitution {
    rank: number;
    rankDisplay: string;
    name: string;
    country: string;
    countryCode: string | null;
  }
  interface LeaderCountry {
    countryCode: string;
    country: string;
    count: number;
  }
  interface Board {
    subject: string;
    label: string;
    provider: string;
    providerLabel: string;
    year: number;
    totalRanked: number;
    countries: LeaderCountry[];
    institutions: LeaderInstitution[];
  }

  const initializeExplorer = (root: HTMLElement) => {
    const dataElement = root.querySelector<HTMLScriptElement>('[data-subject-data]');
    if (!dataElement || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';
    const boards = JSON.parse(dataElement.textContent || '[]') as Board[];
    const providerSelect = root.querySelector<HTMLSelectElement>('[data-provider]');
    const subjectSelect = root.querySelector<HTMLSelectElement>('[data-subject]');
    const countrySelect = root.querySelector<HTMLSelectElement>('[data-subject-country]');
    const chart = root.querySelector<SVGSVGElement>('[data-chart]');
    const caption = root.querySelector<HTMLElement>('[data-chart-caption]');
    const summary = root.querySelector<HTMLElement>('[data-summary]');
    const institutions = root.querySelector<HTMLElement>('[data-institutions]');
    const leadersTitle = root.querySelector<HTMLElement>('[data-leaders-title]');
    const leadersEmpty = root.querySelector<HTMLElement>('[data-leaders-empty]');
    const svgNamespace = 'http://www.w3.org/2000/svg';
    const number = new Intl.NumberFormat('en-US');

    const svgElement = <K extends keyof SVGElementTagNameMap>(
      name: K,
      attributes: Record<string, string | number>,
    ): SVGElementTagNameMap[K] => {
      const element = document.createElementNS(svgNamespace, name);
      Object.entries(attributes).forEach(([key, value]) => {
        element.setAttribute(key, String(value));
      });
      return element;
    };

    const boardsForProvider = () =>
      providerSelect
        ? boards.filter((board) => board.provider === providerSelect.value)
        : boards;

    const selectedBoard = () => {
      const scoped = boardsForProvider();
      return (
        scoped.find((board) => board.subject === subjectSelect?.value) ??
        scoped[0] ??
        boards[0]
      );
    };

    const renderChart = (board: Board, highlightCode: string) => {
      if (!chart) return;
      chart.replaceChildren();
      const rows = board.countries;
      if (rows.length === 0) return;
      const width = 900;
      const height = 360;
      const margin = { left: 176, right: 60, top: 10, bottom: 10 };
      const innerWidth = width - margin.left - margin.right;
      const innerHeight = height - margin.top - margin.bottom;
      const rowHeight = innerHeight / rows.length;
      const barHeight = Math.min(30, rowHeight * 0.62);
      const maxCount = Math.max(...rows.map((row) => row.count));
      const x = scaleLinear().domain([0, maxCount]).range([0, innerWidth]).nice();

      const title = svgElement('title', {});
      title.textContent = `${board.label}: ranked institutions by country`;
      chart.append(title);

      for (const tick of x.ticks(5)) {
        const gx = margin.left + x(tick);
        chart.append(
          svgElement('line', {
            x1: gx,
            x2: gx,
            y1: margin.top,
            y2: height - margin.bottom,
            stroke: '#e3e0d8',
            'stroke-width': 1,
          }),
        );
        const tickLabel = svgElement('text', {
          x: gx,
          y: height - margin.bottom + 2,
          'text-anchor': 'middle',
          'dominant-baseline': 'hanging',
          fill: '#9aa2a1',
          'font-size': 10,
          'font-family': 'ui-monospace, monospace',
        });
        tickLabel.textContent = number.format(tick);
        chart.append(tickLabel);
      }

      rows.forEach((row, index) => {
        const centerY = margin.top + rowHeight * index + rowHeight / 2;
        const barY = centerY - barHeight / 2;
        const barWidth = Math.max(2, x(row.count));

        chart.append(
          svgElement('rect', {
            x: margin.left,
            y: barY,
            width: innerWidth,
            height: barHeight,
            rx: 5,
            fill: '#efece3',
          }),
        );
        const bar = svgElement('rect', {
          x: margin.left,
          y: barY,
          width: barWidth,
          height: barHeight,
          rx: 5,
          fill: highlightCode && row.countryCode === highlightCode ? '#ef6146' : index === 0 ? '#0f766e' : '#17a085',
        });
        const barTitle = svgElement('title', {});
        barTitle.textContent = `${row.country}: ${number.format(row.count)} ranked`;
        bar.append(barTitle);
        chart.append(bar);

        const name = svgElement('text', {
          x: margin.left - 14,
          y: centerY,
          'text-anchor': 'end',
          'dominant-baseline': 'central',
          fill: '#31413f',
          'font-size': 13,
          'font-weight': 600,
        });
        name.textContent = row.country;
        chart.append(name);

        const value = svgElement('text', {
          x: margin.left + barWidth + 8,
          y: centerY,
          'text-anchor': 'start',
          'dominant-baseline': 'central',
          fill: '#5c6b69',
          'font-size': 12,
          'font-family': 'ui-monospace, monospace',
          'font-weight': 600,
        });
        value.textContent = number.format(row.count);
        chart.append(value);
      });
    };

    const renderCountryOptions = (board: Board) => {
      if (!countrySelect) return;
      const previous = countrySelect.value;
      const seen = new Map<string, { country: string; count: number }>();
      for (const institution of board.institutions) {
        const code = institution.countryCode || institution.country;
        if (!code) continue;
        const entry = seen.get(code) ?? { country: institution.country, count: 0 };
        entry.count += 1;
        seen.set(code, entry);
      }
      const entries = [...seen.entries()].sort(
        (a, b) => b[1].count - a[1].count || (a[1].country < b[1].country ? -1 : 1),
      );
      const options: HTMLOptionElement[] = [];
      const all = document.createElement('option');
      all.value = '';
      all.textContent = 'All countries';
      options.push(all);
      for (const [code, info] of entries) {
        const option = document.createElement('option');
        option.value = code;
        option.textContent = `${info.country} (${info.count})`;
        options.push(option);
      }
      countrySelect.replaceChildren(...options);
      countrySelect.value = entries.some(([code]) => code === previous) ? previous : '';
    };

    const render = () => {
      if (!summary || !institutions) return;
      const board = selectedBoard();
      if (!board) return;
      const selectedCountry = countrySelect?.value ?? '';

      if (caption) {
        caption.textContent = `Ranked institutions by home system · ${board.providerLabel} ${board.year}`;
      }
      if (chart) {
        chart.setAttribute('aria-label', `${board.label}: ranked institutions by country`);
      }

      const leadCountry = board.countries[0];
      const summaryField = document.createElement('span');
      summaryField.textContent = `${board.providerLabel} ${board.year}`;
      const summaryTotal = document.createElement('strong');
      const totalValue = document.createElement('b');
      totalValue.textContent = number.format(board.totalRanked);
      summaryTotal.append(totalValue, ' ranked institutions');
      const summaryLead = document.createElement('small');
      summaryLead.textContent = leadCountry
        ? `Led by ${leadCountry.country} (${number.format(leadCountry.count)} listed)`
        : 'No country breakdown available';
      summary.replaceChildren(summaryField, summaryTotal, summaryLead);

      renderChart(board, selectedCountry);

      const filtered = selectedCountry
        ? board.institutions.filter((institution) => (institution.countryCode || institution.country) === selectedCountry)
        : board.institutions;

      if (leadersTitle) {
        const countryName = filtered[0]?.country ?? '';
        leadersTitle.textContent = selectedCountry
          ? `Top ${countryName} institutions in ${board.label}`
          : `Top institutions in ${board.label}`;
      }

      institutions.replaceChildren(
        ...filtered.map((institution) => {
          const item = document.createElement('li');
          const rank = document.createElement('span');
          rank.className = 'rank';
          rank.textContent = `#${institution.rankDisplay}`;
          const identity = document.createElement('span');
          identity.className = 'identity';
          const name = document.createElement('strong');
          name.textContent = institution.name;
          const country = document.createElement('small');
          country.textContent = institution.country;
          identity.append(name, country);
          item.append(rank, identity);
          return item;
        }),
      );

      if (leadersEmpty) {
        const empty = filtered.length === 0;
        leadersEmpty.hidden = !empty;
        institutions.hidden = empty;
        if (empty) {
          leadersEmpty.textContent = `No institution from this country appears in the top ${board.institutions.length} of ${board.label}.`;
        }
      }
    };

    const onSubjectChange = () => {
      const board = selectedBoard();
      if (board) renderCountryOptions(board);
      render();
    };

    const onProviderChange = () => {
      if (!subjectSelect) return;
      const scoped = boardsForProvider();
      subjectSelect.replaceChildren(
        ...scoped.map((board) => {
          const option = document.createElement('option');
          option.value = board.subject;
          option.textContent = board.label;
          return option;
        }),
      );
      subjectSelect.value = scoped[0]?.subject ?? '';
      subjectSelect.dispatchEvent(new Event('change', { bubbles: true }));
    };

    providerSelect?.addEventListener('change', onProviderChange);
    subjectSelect?.addEventListener('change', onSubjectChange);
    countrySelect?.addEventListener('change', render);

    const initialBoard = selectedBoard();
    if (initialBoard) renderCountryOptions(initialBoard);
    render();
  };

  const initializeSubjectExplorers = () => {
    document
      .querySelectorAll<HTMLElement>('[data-subject-explorer]')
      .forEach((root) => initializeExplorer(root));
  };

  initializeSubjectExplorers();
  document.addEventListener('astro:page-load', initializeSubjectExplorers);
</script>

<style>
  .subject-explorer {
    padding: 24px;
  }

  .controls {
    display: grid;
    grid-template-columns: minmax(0, 2.2fr) minmax(200px, 1fr);
    align-items: end;
    gap: 16px;
  }

  .control-fields {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 14px;
    align-items: end;
  }

  label {
    display: grid;
    gap: 6px;
  }

  label span {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .subject-summary {
    display: grid;
    align-content: end;
    min-height: 44px;
    padding-left: 18px;
    border-left: 1px solid var(--line);
  }

  .subject-summary :global(span),
  .subject-summary :global(small) {
    color: var(--muted);
    font-size: 0.63rem;
  }

  .subject-summary :global(strong) {
    font-size: 0.82rem;
  }

  .subject-summary :global(b) {
    color: var(--teal-dark);
  }

  .explorer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: 20px;
    margin-top: 22px;
  }

  .chart-block {
    margin: 0;
  }

  figcaption {
    margin-bottom: 10px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .chart-frame {
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background:
      linear-gradient(rgb(255 253 248 / 94%), rgb(255 253 248 / 94%)),
      radial-gradient(circle, #bdbab1 1px, transparent 1px);
    background-size: auto, 12px 12px;
  }

  svg {
    width: 100%;
    height: auto;
  }

  .leaders-block {
    display: grid;
    align-content: start;
    gap: 10px;
  }

  .leaders-title {
    margin: 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .leaders {
    margin: 0;
    padding: 0;
    list-style: none;
    max-height: 420px;
    overflow-y: auto;
  }

  .leaders-empty {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .leaders :global(li) {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    align-items: center;
    gap: 12px;
    padding: 9px 0;
    border-top: 1px solid var(--line);
  }

  .leaders :global(li:first-child) {
    border-top: 0;
  }

  .leaders :global(.rank) {
    color: var(--teal-dark);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .leaders :global(.identity) {
    display: grid;
    min-width: 0;
  }

  .leaders :global(.identity strong) {
    overflow: hidden;
    font-size: 0.76rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .leaders :global(.identity small) {
    color: var(--muted);
    font-size: 0.6rem;
  }

  .fine-print {
    margin: 16px 0 0;
  }

  @media (max-width: 820px) {
    .controls {
      grid-template-columns: 1fr;
    }

    .subject-summary {
      padding: 12px 0 0;
      border-top: 1px solid var(--line);
      border-left: 0;
    }

    .explorer-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .subject-explorer {
      padding: 16px;
    }

    .chart-frame {
      overflow-x: auto;
    }

    svg {
      min-width: 520px;
    }
  }
</style>
